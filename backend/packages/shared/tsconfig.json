{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": ".",
    "outDir": "./dist",

    "declaration": true,

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "index.ts",
    "jwt/**/*",
    "middlewares/**/*",
    "errors/**/*",
    "types/**/*"
  ],

  "exclude": [
    "dist",
    "node_modules"
  ]
}