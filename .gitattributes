# Set the default behavior to automatically handle line endings.
* text=auto eol=lf

# Explicitly declare text files you want to always have LF line endings.
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.proto text eol=lf

# Declare files that should always have CRLF endings (e.g., Windows batch files)
*.bat text eol=crlf